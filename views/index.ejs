<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Note-making-Web-app</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="container m-full min-h-screen bg-zinc-900">
    <div class="form p-10 text-white">
        <form action="/create" method="POST"">
            <input 
                class="block w-full rounded-md px-5 py-2 bg-zinc-800" 
                type="text" 
                placeholder="Title goes here"
                name="title"
                >

                <textarea 
                class="block w-full rounded-md my-2 px-5 py-2 resize-none bg-zinc-800" 
                placeholder="Write here task details"
                name="details"

                ></textarea>

                <input 
                class="mt-2 bg-blue-600 px-5 py-2 rounded-md cursor-pointer" 
                type="submit" 
                value="Create a task"
                >
        </form >
        <div class="task flex gap-3 p-10">
            <% if(files.length >0) { %>
                <% files.forEach(function(val){ %>
                    <div class="task w-72 px-3 py-4 rounded-md bg-zinc-800">
                        <h1 class="text-lg font-bold"><%= val %></h1>
                        <a href="/file/<%= val %>" class="text-blue-500 hover:underline">Read More...</a>
                    </div>
                <% }) %>
            <% } else { %>
                <h3 class="text-white">No tasks available.</h3>
            <% } %>
        </div>

            </div>
        </div>
    </div>
    </div>
</body>
</html>